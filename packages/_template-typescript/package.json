{
  "name": "template-typescript",
  "version": "0.1.0",
  "description": "TypeScript 패키지 시작 템플릿 — 새 util을 만들 때 이 폴더를 복사해서 시작",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "template-typescript": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
