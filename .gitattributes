# 기본: 텍스트 자동 감지 + 저장소는 LF, 체크아웃도 LF (Windows/Linux 통일)
* text=auto eol=lf

# Windows 전용 스크립트만 CRLF 강제
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 명시적으로 바이너리 (CRLF 변환 금지)
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.zip binary
*.gz binary
*.tar binary
*.7z binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
